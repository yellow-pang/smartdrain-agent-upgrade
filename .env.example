# Docker Compose / 배포 입력값
# 운영 비밀값은 이 파일이나 Git에 저장하지 말고 AWS Secrets Manager 또는 GitHub Actions Secrets로 주입합니다.
COMPOSE_PROJECT_NAME=smartdrain
NGINX_HTTP_PORT=80
NGINX_DEV_HTTP_PORT=8080
POSTGRES_USER=smartdrain
POSTGRES_PASSWORD=change-me-for-non-local-environments
POSTGRES_DB=smartdrain_db
COMPOSE_DATABASE_URL=postgresql+psycopg://smartdrain:change-me-for-non-local-environments@db:5432/smartdrain_db
# Nginx same-origin(/api, /ws) 요청에는 CORS가 적용되지 않습니다.
# 브라우저가 backend를 직접 호출해야 할 때만 해당 origin을 JSON 배열로 추가합니다.
# Cloudflare Tunnel 운영 예시: ["https://smartdrain.healthq.store"]
COMPOSE_CORS_ORIGINS=["http://localhost","http://localhost:8080"]
COMPOSE_AI_SERVER_ENABLED=true
COMPOSE_AI_SERVER_TIMEOUT_SECONDS=10
COMPOSE_ANALYSIS_SCHEDULER_ENABLED=false
COMPOSE_ANALYSIS_SCHEDULER_INTERVAL_SECONDS=300
COMPOSE_ANALYSIS_SCHEDULER_INITIAL_DELAY_SECONDS=60
COMPOSE_ANALYSIS_SENSOR_MAX_AGE_SECONDS=300
COMPOSE_ANALYSIS_JOB_TIMEOUT_SECONDS=600
COMPOSE_DEMO_SIMULATOR_ENABLED=false
COMPOSE_DEMO_SIMULATOR_MODE=direct
COMPOSE_DEMO_SIMULATOR_INTERVAL_SECONDS=30
COMPOSE_DEMO_SIMULATOR_START_DELAY_SECONDS=10
COMPOSE_DEMO_SIMULATOR_TARGET_DRAIN_CODE=DR-003
COMPOSE_DEMO_SIMULATOR_AUTO_START=false
DEMO_CONTROL_TOKEN=change-me-for-demo-control
COMPOSE_BACKEND_CALLBACK_TIMEOUT_SECONDS=10
COMPOSE_BACKEND_CALLBACK_RETRY_COUNT=1
# Git 외부의 존재하는 YOLO 모델 파일을 지정합니다.
# Windows 예시: C:/smartdrain-data/models/best.pt
# Linux/VM 예시: /home/<VM-user>/apps/opt/smartdrain-data/models/best.pt
# 파일이 없거나 비어 있으면 ai-service가 ERROR 로그를 남기고 기동하지 않습니다.
# XGBoost 모델 JSON은 Git으로 추적하며 Docker image에 포함됩니다.
SMARTDRAIN_YOLO_MODEL_PATH=./ai_service/model/best.pt
# Docker Compose frontend의 공개 설정입니다. NEXT_PUBLIC_* 이름은 frontend 로컬 .env.local 전용입니다.
# 빈 값이면 브라우저의 same-origin을 사용한다. API 함수가 이미 /api 경로를 포함한다.
COMPOSE_FRONTEND_API_BASE_URL=
COMPOSE_FRONTEND_KAKAO_MAP_APP_KEY=
