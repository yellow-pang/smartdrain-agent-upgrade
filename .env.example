# Docker Compose / 배포 입력값
# 운영 비밀값은 이 파일이나 Git에 저장하지 말고 AWS Secrets Manager 또는 GitHub Actions Secrets로 주입합니다.
COMPOSE_PROJECT_NAME=smartdrain
NGINX_HTTP_PORT=80
NGINX_DEV_HTTP_PORT=8080
POSTGRES_USER=smartdrain
POSTGRES_PASSWORD=change-me-for-non-local-environments
POSTGRES_DB=smartdrain_db
COMPOSE_DATABASE_URL=postgresql+psycopg://smartdrain:change-me-for-non-local-environments@db:5432/smartdrain_db
COMPOSE_CORS_ORIGINS=["http://localhost","http://localhost:8080"]
COMPOSE_AI_SERVER_ENABLED=true
COMPOSE_AI_SERVER_TIMEOUT_SECONDS=10
COMPOSE_BACKEND_CALLBACK_TIMEOUT_SECONDS=10
COMPOSE_BACKEND_CALLBACK_RETRY_COUNT=1
