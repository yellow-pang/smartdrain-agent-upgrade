# 백엔드를 Docker 없이 로컬 실행할 때 사용하는 서비스 설정입니다.
PROJECT_NAME=Flood Monitoring Backend
DATABASE_URL=postgresql+psycopg://smartdrain:smartdrain123@localhost:5432/smartdrain_db
CORS_ORIGINS=["http://localhost:3000"]
AI_SERVER_BASE_URL=http://localhost:9000
AI_SERVER_TIMEOUT_SECONDS=10
AI_CALLBACK_BASE_URL=http://localhost:8000
AI_SERVER_ENABLED=true
ANALYSIS_SCHEDULER_ENABLED=false
ANALYSIS_SCHEDULER_INTERVAL_SECONDS=300
ANALYSIS_SCHEDULER_INITIAL_DELAY_SECONDS=60
ANALYSIS_SENSOR_MAX_AGE_SECONDS=300
ANALYSIS_JOB_TIMEOUT_SECONDS=600
DEMO_SIMULATOR_ENABLED=false
DEMO_SIMULATOR_MODE=direct
DEMO_SIMULATOR_INTERVAL_SECONDS=30
DEMO_SIMULATOR_START_DELAY_SECONDS=10
DEMO_SIMULATOR_TARGET_DRAIN_CODE=DR-003
