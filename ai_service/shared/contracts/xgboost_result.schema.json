{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xgboost_result.schema.json",
  "title": "XGBoost result record",
  "type": "object",
  "required": [
    "xgboost_id",
    "drain_id",
    "sensor_measured_at",
    "yolo_result_id",
    "evaluated_at",
    "risk_score",
    "risk_level",
    "final_decision",
    "analysis_status",
    "data_quality",
    "state_code",
    "reason_codes"
  ],
  "properties": {
    "xgboost_id": {"type": "integer", "minimum": 1},
    "drain_id": {"type": "integer", "minimum": 1},
    "sensor_measured_at": {
      "oneOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ]
    },
    "yolo_result_id": {"type": "integer", "minimum": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "risk_score": {
      "oneOf": [
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "null"}
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": ["good", "caution", "danger", "unknown"]
    },
    "final_decision": {
      "type": "string",
      "enum": ["normal", "monitoring", "field_check", "dispatch_required", "review_required"]
    },
    "analysis_status": {
      "type": "string",
      "enum": ["completed", "degraded", "skipped", "failed"]
    },
    "data_quality": {
      "type": "string",
      "enum": ["valid", "suspect", "stale", "insufficient", "invalid"]
    },
    "state_code": {"type": "string"},
    "reason_codes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false
}
