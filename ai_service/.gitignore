# Python virtual environments
.venv/
venv/
**/.venv/
**/venv/

# Python caches and build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/

# Test, type-check, lint, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local environment and secrets
.env
.env.*
!.env.example
*.pem
*.key

# IDE and OS metadata
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime outputs generated from mock analysis
xgboost/mock_data/runtime/*.jsonl
xgboost/mock_data/runtime/*.log
!xgboost/mock_data/runtime/.gitkeep

# Logs and temporary files
logs/
*.log
tmp/
.cache/
.codex-log/

# Training scratch outputs (tracked baseline models under xgboost/models are not ignored)
xgboost/training_output/
xgboost/models/*.tmp
xgboost/models/*.bak

# Notebook checkpoints
.ipynb_checkpoints/
