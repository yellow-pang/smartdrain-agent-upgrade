# Data source. Current scaffold supports mock; postgres is a future adapter target.
DATA_SOURCE=mock

# Paths are relative to the ai_service repository root unless absolute.
MOCK_DATA_DIR=mock_data
MODEL_PATH=xgboost/models/xgb_mock_baseline.json
MODEL_METADATA_PATH=xgboost/models/model_metadata.json

# Time-window feature configuration
SENSOR_LOOKBACK_MINUTES=30
SENSOR_SHORT_WINDOW_MINUTES=5
MAX_SENSOR_AGE_SECONDS=300
MIN_SENSOR_COUNT_30M=3

# Data quality policy
MIN_YOLO_CONFIDENCE=0.15
ALLOW_SENSOR_DANGER_OVERRIDE=true

# Future PostgreSQL adapter
DATABASE_URL=postgresql+psycopg://flood_user:flood_password@localhost:5432/flood_db

# Logging
LOG_LEVEL=INFO
